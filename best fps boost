local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({
   Name = "GOJO V1 | FOCUS PS99 🟣",
   LoadingTitle = "Gojo Farming Mode...",
   LoadingSubtitle = "by Tuan Nando",
   Theme = "Purple"
})

local FarmTab = Window:CreateTab("Auto Farm", 4483362458)

_G.AutoFarm = false
_G.AutoCollect = false
_G.AutoHatch = false

FarmTab:CreateToggle({
   Name = "ULTRA FAST FARM (NO CURE)",
   CurrentValue = false,
   Callback = function(V)
      _G.AutoFarm = V
      if V then task.spawn(function()
         while _G.AutoFarm do
            pcall(function()
               local b = game:GetService("Workspace").__THINGS.Breakables:GetChildren()
               for i = 1, 30 do -- 30 TARGET BIAR MELEDAK!
                  if b[i] and b[i]:FindFirstChild("Hitbox") then
                     game:GetService("ReplicatedStorage").Network.Breakables_PlayerAttackBreakable:FireServer(b[i].Name)
                  end
               end
            end)
            task.wait(0.01) -- SPEED GILA!
         end
      end) end
   end,
})

FarmTab:CreateToggle({
   Name = "AUTO COLLECT ORBS",
   CurrentValue = false,
   Callback = function(V)
      _G.AutoCollect = V
      if V then task.spawn(function()
         while _G.AutoCollect do
            game:GetService("ReplicatedStorage").Network.Orbs_Collect:FireServer({})
            task.wait(0.1)
         end
      end) end
   end,
})

FarmTab:CreateToggle({
   Name = "HUGE HUNTER (AUTO HATCH)",
   CurrentValue = false,
   Callback = function(V)
      _G.AutoHatch = V
      if V then task.spawn(function()
         while _G.AutoHatch do
            game:GetService("ReplicatedStorage").Network.Eggs_RequestPurchase:InvokeServer("Spawn", 1)
            task.wait(0.001) -- UNLIMITED VOID HATCH!
         end
      end) end
   end,
})

Rayfield:Notify({Title = "FOCUS MODE ON", Content = "Bantai Semua, Raja!", Duration = 5})
